{% doc %}
  @prompt
    A heading with an animated glowing effect
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-glow-heading-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-glow-heading__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.text_color }};
    margin: 0;
    padding: 20px;
    position: relative;
    display: inline-block;
    width: 100%;
  }

  .ai-glow-heading__text-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: {{ block.settings.glow_radius }}px;
    background: {{ block.settings.glow_color }};
    filter: blur({{ block.settings.glow_blur }}px);
    opacity: {{ block.settings.glow_opacity }};
    z-index: -1;
    animation: ai-glow-pulse-{{ ai_gen_id }} {{ block.settings.animation_speed }}s ease-in-out infinite;
  }

  @keyframes ai-glow-pulse-{{ ai_gen_id }} {
    0%, 100% {
      opacity: {{ block.settings.glow_opacity }};
      transform: scale(1);
    }
    50% {
      opacity: {{ block.settings.glow_opacity | times: 1.5 | at_most: 1 }};
      transform: scale(1.05);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-glow-heading__text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.7);
    }
  }
{% endstyle %}

<glow-heading-{{ ai_gen_id }} class="ai-glow-heading-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading_tag == 'h1' %}
    <h1 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h1>
  {% elsif block.settings.heading_tag == 'h2' %}
    <h2 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h2>
  {% elsif block.settings.heading_tag == 'h3' %}
    <h3 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h3>
  {% elsif block.settings.heading_tag == 'h4' %}
    <h4 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h4>
  {% elsif block.settings.heading_tag == 'h5' %}
    <h5 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h5>
  {% else %}
    <h6 class="ai-glow-heading__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h6>
  {% endif %}
</glow-heading-{{ ai_gen_id }}>

<script>
  (function() {
    class GlowHeading{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('glow-heading-{{ ai_gen_id }}', GlowHeading{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Glow heading",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading text",
      "default": "Glowing Heading"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        },
        {
          "value": "800",
          "label": "Extra bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Glow effect"
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Glow color",
      "default": "#dca1a1"
    },
    {
      "type": "range",
      "id": "glow_blur",
      "label": "Glow blur",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "glow_opacity",
      "label": "Glow opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.8
    },
    {
      "type": "range",
      "id": "glow_radius",
      "label": "Glow radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
