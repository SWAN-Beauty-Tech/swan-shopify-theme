    {
      "type": "range",
      "id": "animation_speed",
      "label": "Animation speed",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "s",
      "default": 2
    }
  ],
  "presets": [
    {
      "name": "Glow heading"
    }
  ]
}
{% endschema %}
